<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_field_sales_visit_list" model="ir.ui.view">
        <field name="name">field.sales.visit.list</field>
        <field name="model">field.sales.visit</field>
        <field name="arch" type="xml">
            <list>
                <field name="company_name"/>
                <field name="contact_name"/>
                <field name="phone"/>
                <field name="session_id"/>
                <field name="check_in_time"/>
                <field name="check_out_time"/>
                <field name="duration" widget="float_time"/>
                <field name="partner_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_field_sales_visit_form" model="ir.ui.view">
        <field name="name">field.sales.visit.form</field>
        <field name="model">field.sales.visit</field>
        <field name="arch" type="xml">
            <form string="Client Visit">
                <sheet>
                    <group>
                        <group string="Client details">
                            <field name="company_name"/>
                            <field name="contact_name"/>
                            <field name="phone"/>
                            <field name="partner_id" readonly="1"/>
                        </group>
                        <group string="Visit Timings &amp; Location">
                            <field name="session_id" readonly="1"/>
                            <field name="check_in_time"/>
                            <field name="check_out_time"/>
                            <field name="duration" widget="float_time"/>
                            <field name="latitude"/>
                            <field name="longitude"/>
                            <field name="accuracy"/>
                        </group>
                    </group>
                    <group>
                        <group string="Verification Photo">
                            <field name="visit_image" widget="image" class="oe_avatar" readonly="1" string="Visit Photo"/>
                        </group>
                    </group>
                    <group string="Feedback/Notes">
                        <field name="notes" placeholder="Add details about lead progress, next visit dates, requirements, etc..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_field_sales_visit" model="ir.actions.act_window">
        <field name="name">Client Visits</field>
        <field name="res_model">field.sales.visit</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No client visits logged yet.
            </p>
            <p>
                Sales representatives can log client visits during their active sessions.
            </p>
        </field>
    </record>
</odoo>
