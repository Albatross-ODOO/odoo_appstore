<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Security Category -->
        <record id="module_category_field_sales" model="ir.module.category">
            <field name="name">Field Sales Tracking</field>
            <field name="description">User access levels for field sales activity tracking.</field>
            <field name="sequence">300</field>
        </record>

        <!-- Representative Group -->
        <record id="group_salesperson" model="res.groups">
            <field name="name">Representative</field>
            <field name="category_id" ref="field_sales.module_category_field_sales"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Manager Group -->
        <record id="group_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="field_sales.module_category_field_sales"/>
            <field name="implied_ids" eval="[(4, ref('field_sales.group_salesperson'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
