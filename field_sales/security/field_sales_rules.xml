<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Session Rules -->
        <record id="field_sales_session_salesperson_rule" model="ir.rule">
            <field name="name">Salesperson: Own Sessions Only</field>
            <field name="model_id" ref="model_field_sales_session"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('field_sales.group_salesperson'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="field_sales_session_manager_rule" model="ir.rule">
            <field name="name">Manager: All Sessions</field>
            <field name="model_id" ref="model_field_sales_session"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('field_sales.group_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Visit Rules -->
        <record id="field_sales_visit_salesperson_rule" model="ir.rule">
            <field name="name">Salesperson: Own Visits Only</field>
            <field name="model_id" ref="model_field_sales_visit"/>
            <field name="domain_force">[('session_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('field_sales.group_salesperson'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="field_sales_visit_manager_rule" model="ir.rule">
            <field name="name">Manager: All Visits</field>
            <field name="model_id" ref="model_field_sales_visit"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('field_sales.group_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Location Log Rules -->
        <record id="field_sales_location_log_salesperson_rule" model="ir.rule">
            <field name="name">Salesperson: Own Location Logs Only</field>
            <field name="model_id" ref="model_field_sales_location_log"/>
            <field name="domain_force">[('session_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('field_sales.group_salesperson'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="field_sales_location_log_manager_rule" model="ir.rule">
            <field name="name">Manager: All Location Logs</field>
            <field name="model_id" ref="model_field_sales_location_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('field_sales.group_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
